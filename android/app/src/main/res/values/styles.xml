<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:colorBackground">#0B0B14</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:textColor">#E8E6F0</item>
        <item name="android:colorPrimary">#7C5CFC</item>
        <item name="android:colorPrimaryDark">#6C4CE0</item>
        <item name="android:colorAccent">#5CE0D8</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="AppTheme.Fullscreen" parent="AppTheme">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
